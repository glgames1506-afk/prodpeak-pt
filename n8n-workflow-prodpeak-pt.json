        "jsonBody": "={ \"model\": \"openai/gpt-3.5-turbo\", \"messages\": [{ \"role\": \"system\", \"content\": \"Você é um redator elite especializado em produtividade, biohacking e neurociência. Escreva artigos de 2500+ palavras em português do Brasil. Retorne APENAS JSON válido com: title, body_html, slug, category, meta_desc.\" }, { \"role\": \"user\", \"content\": \"Escreva um artigo completo sobre: {{ $json.keyword }}\" }] }"
