    {
      "parameters": {
        "jsCode": "const r = $node['IA - Redator Royal'].json.choices[0].message.content; const ai = JSON.parse(r.match(/\\{[\\s\\S]*\\}/)[0]); const h = `<html><head><meta charset='UTF-8'><link rel='stylesheet' href='../styles.css'><title>${ai.title}</title></head><body><main class='container'><div class='badge'>⏱️ LEITURA DE 10 MINUTOS</div><h1>${ai.title}</h1><div class='content'>${ai.body_html}</div><div class='cta-box' style='background:#1b4332; padding:50px; border-radius:12px; margin-top:40px; text-align:center;'><h3>📚 Leitura Recomendada</h3><p>Este conteúdo transformou a vida de milhares. Aprofunde-se com os melhores livros do mercado.</p><a href='https://amzn.to/4moudI5' target='_blank' style='display:inline-block; margin-top:16px; padding:16px 32px; background:#e9c46a; color:#1b4332; text-decoration:none; border-radius:8px; font-weight:bold;'>Ver na Amazon →</a></div></main></body></html>`; return { html: h, filename: `${ai.slug}.html` };"
      },
